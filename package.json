{
  "name": "tabnews",
  "version": "1.0.0",
  "description": "Criação do clone do tabnews para fins educacionas",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && next dev",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "service:up": "docker compose -f infra/compose.yaml up -d",
    "service:down": "docker compose -f infra/compose.yaml down",
    "service:stop": "docker compose -f infra/compose.yaml stop"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaovitordesp/tabnews.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joaovitordesp/tabnews/issues"
  },
  "homepage": "https://github.com/joaovitordesp/tabnews#readme",
  "dependencies": {
    "next": "^13.1.6",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "prettier": "^3.8.3"
  }
}
